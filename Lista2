horas_trab = float(input("Horas trabalhadas: "))
bruto = ganho_hora * horas_trab

ir = bruto * 0.11
inss = bruto * 0.08
sindicato = bruto * 0.05
liquido = bruto - ir - inss - sindicato

print(f"Salário Bruto: R$ {bruto}")
print(f"Descontos -> IR: R$ {ir} | INSS: R$ {inss} | Sindicato: R$ {sindicato}")
print(f"Salário Líquido: R$ {liquido}")

