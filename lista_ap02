#5. Processamento de Lista com Dicionário:
def produto_mais_caro(produtos):
    return max(produtos, key=lambda p: p["preco"])
lista = [
    {"nome": "Notebook", "preco": 3500.00},
    {"nome": "Mouse",    "preco": 150.00},
    {"nome": "Monitor",  "preco": 1200.00}
]
mais_caro = produto_mais_caro(lista)
print(f"Produto mais caro: {mais_caro['nome']} — R$ {mais_caro['preco']:.2f}")
