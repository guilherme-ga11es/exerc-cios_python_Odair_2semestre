# Exercício 28: Hipermercado Tabajara
tipo = int(input("1-Filé, 2-Alcatra, 3-Picanha: "))
kg = float(input("Kg: "))
cartao = input("Cartão Tabajara (S/N): ").upper()
preços = {1: (4.9, 5.8), 2: (5.9, 6.8), 3: (6.9, 7.8)}
p_unit = preços[tipo][0] if kg <= 5 else preços[tipo][1]
