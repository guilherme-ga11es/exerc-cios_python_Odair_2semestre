# Exercício 16: Equação 2º Grau
import math
a = float(input("A: "))
if a == 0: print("Não é 2º grau")
else:
    b, c = float(input("B: ")), float(input("C: "))
    delta = b**2 - 4*a*c
    if delta < 0: print("Sem raízes reais")
    elif delta == 0: print("Raiz única:", -b/(2*a))
    else: print("X1:", (-b+math.sqrt(delta))/(2*a), "X2:", (-b-math.sqrt(delta))/(2*a))

